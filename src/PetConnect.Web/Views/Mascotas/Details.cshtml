@model PetConnect.Domain.Entities.Mascota

@{
    ViewData["Title"] = $"Detalle de {Model.Nombre}";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="detail-panel">
            <a class="btn btn-link px-0 mb-3" asp-action="Index">Volver a mascotas</a>
            <div class="d-flex flex-wrap justify-content-between gap-3">
                <div>
                    <h1 class="h2">@Model.Nombre</h1>
                    <p class="text-secondary">@Model.Especie - @Model.Raza</p>
                </div>
                <span class="badge align-self-start text-bg-success">Disponible</span>
            </div>
            <dl class="row mt-4">
                <dt class="col-sm-3">Edad</dt>
                <dd class="col-sm-9">@Model.Edad anios</dd>
                <dt class="col-sm-3">Descripcion</dt>
                <dd class="col-sm-9">@Model.Descripcion</dd>
            </dl>
            <a class="btn btn-primary" asp-controller="Solicitudes" asp-action="Create" asp-route-mascotaId="@Model.Id">Crear solicitud</a>
        </div>
    </div>
</div>

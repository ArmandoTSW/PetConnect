@model PetConnect.Domain.Entities.Mascota

@{
    ViewData["Title"] = $"Detalle de {Model.Nombre}";
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <section class="detail-panel">
            <a class="back-link" asp-action="Index">Volver a mascotas</a>
            <div class="row g-4 align-items-center">
                <div class="col-md-4">
                    <div class="pet-detail-avatar">@Model.Nombre.Substring(0, 1)</div>
                </div>
                <div class="col-md-8">
                    <span class="status-pill">Disponible</span>
                    <h1>@Model.Nombre</h1>
                    <p class="lead text-secondary">@Model.Especie - @Model.Raza</p>
                    <dl class="detail-list">
                        <div>
                            <dt>Edad</dt>
                            <dd>@Model.Edad anios</dd>
                        </div>
                        <div>
                            <dt>Descripcion</dt>
                            <dd>@Model.Descripcion</dd>
                        </div>
                    </dl>
                    <a class="btn btn-primary btn-lg" asp-controller="Solicitudes" asp-action="Create" asp-route-mascotaId="@Model.Id">Crear solicitud</a>
                </div>
            </div>
        </section>
    </div>
</div>

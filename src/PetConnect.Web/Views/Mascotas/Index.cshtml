@model IReadOnlyList<PetConnect.Domain.Entities.Mascota>

@{
    ViewData["Title"] = "Mascotas disponibles";
}

<section class="page-title">
    <div>
        <span>Mascotas</span>
        <h1>Mascotas disponibles</h1>
        <p>Elige una mascota para conocer su historia o iniciar una solicitud de adopcion.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Adoptantes" asp-action="Create">Registrar adoptante</a>
</section>

<div class="row g-4">
    @foreach (var mascota in Model)
    {
        <div class="col-md-6 col-xl-4">
            <article class="pet-card h-100">
                <div class="pet-avatar">@mascota.Nombre.Substring(0, 1)</div>
                <div class="pet-card-body">
                    <div class="d-flex justify-content-between align-items-start gap-2">
                        <div>
                            <h2>@mascota.Nombre</h2>
                            <p class="pet-meta">@mascota.Especie - @mascota.Raza</p>
                        </div>
                        <span class="status-pill">Disponible</span>
                    </div>
                    <p class="pet-description">@mascota.Descripcion</p>
                    <div class="pet-facts">
                        <span>@mascota.Edad anios</span>
                        <span>@mascota.Especie</span>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <a class="btn btn-outline-primary flex-fill" asp-action="Details" asp-route-id="@mascota.Id">Detalle</a>
                        <a class="btn btn-primary flex-fill" asp-controller="Solicitudes" asp-action="Create" asp-route-mascotaId="@mascota.Id">Solicitar</a>
                    </div>
                </div>
            </article>
        </div>
    }
</div>

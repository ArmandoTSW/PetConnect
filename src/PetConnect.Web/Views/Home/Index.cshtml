@{
    ViewData["Title"] = "Inicio";
}

<section class="hero-section">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <span class="eyebrow">Gestion de adopciones</span>
            <h1>PetConnect</h1>
            <p class="hero-copy">
                Una plataforma escolar para consultar mascotas disponibles, registrar adoptantes y dar seguimiento a solicitudes desde una interfaz web clara y presentable.
            </p>
            <div class="d-flex flex-wrap gap-2 mt-4">
                <a class="btn btn-light btn-lg" asp-controller="Mascotas" asp-action="Index">Ver mascotas</a>
                <a class="btn btn-outline-light btn-lg" asp-controller="Solicitudes" asp-action="Create">Crear solicitud</a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="hero-panel">
                <div class="metric">
                    <strong>3</strong>
                    <span>Mascotas iniciales</span>
                </div>
                <div class="metric">
                    <strong>3</strong>
                    <span>Estados de solicitud</span>
                </div>
                <div class="metric">
                    <strong>MVC + API</strong>
                    <span>Interfaz web y pruebas con Swagger</span>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-heading">
    <span>Flujo principal</span>
    <h2>Todo el proceso en pocas pantallas</h2>
</section>

<section class="row g-3">
    <div class="col-md-4">
        <div class="feature-box">
            <span class="feature-icon">1</span>
            <h3>Mascotas</h3>
            <p>Consulta nombre, especie, edad, descripcion y disponibilidad antes de crear una solicitud.</p>
            <a asp-controller="Mascotas" asp-action="Index">Explorar mascotas</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-box">
            <span class="feature-icon">2</span>
            <h3>Adoptantes</h3>
            <p>Registra informacion de contacto para relacionarla con una adopcion.</p>
            <a asp-controller="Adoptantes" asp-action="Create">Registrar adoptante</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-box">
            <span class="feature-icon">3</span>
            <h3>Solicitudes</h3>
            <p>Crea solicitudes y cambia su estado a pendiente, aprobada o rechazada.</p>
            <a asp-controller="Solicitudes" asp-action="Index">Ver solicitudes</a>
        </div>
    </div>
</section>

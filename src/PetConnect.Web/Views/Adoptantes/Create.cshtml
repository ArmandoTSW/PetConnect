@model PetConnect.Domain.Entities.Adoptante

@{
    ViewData["Title"] = "Registrar adoptante";
}

<section class="page-title narrow">
    <div>
        <span>Adoptantes</span>
        <h1>Registrar adoptante</h1>
        <p>Guarda los datos basicos de la persona interesada antes de crear una solicitud.</p>
    </div>
</section>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <section class="form-panel">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <div class="row g-3">
                    <div class="col-md-12">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre" class="form-control form-control-lg" placeholder="Nombre completo" required />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Correo" class="form-label"></label>
                        <input asp-for="Correo" type="email" class="form-control" placeholder="correo@ejemplo.com" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Telefono" class="form-label"></label>
                        <input asp-for="Telefono" class="form-control" placeholder="Telefono de contacto" />
                    </div>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary btn-lg">Guardar adoptante</button>
                    <a class="btn btn-outline-secondary btn-lg" asp-controller="Solicitudes" asp-action="Create">Ir a solicitud</a>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
